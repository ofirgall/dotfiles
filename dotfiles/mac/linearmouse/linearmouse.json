{
  "$schema" : "https:\/\/schema.linearmouse.app\/0.11.2",
  "schemes" : [
    {
      "if" : {
        "device" : {
          "category" : "trackpad"
        }
      },
      "pointer" : {
        "disableAcceleration" : true
      },
      "scrolling" : {

      }
    },
    {
      "if" : {
        "device" : {
          "category" : "trackpad",
          "productID" : "0x0",
          "productName" : "Apple Internal Keyboard \/ Trackpad",
          "vendorID" : "0x0"
        }
      },
      "pointer" : {
        "acceleration" : 1,
        "disableAcceleration" : false,
        "speed" : 0
      }
    },
    {
      "if" : {
        "device" : {
          "category" : "mouse",
          "productID" : "0xc548",
          "productName" : "USB Receiver",
          "vendorID" : "0x46d"
        }
      },
      "pointer" : {
        "acceleration" : 1.15,
        "disableAcceleration" : true,
        "redirectsToScroll" : false
      },
      "scrolling" : {
        "reverse" : {
          "vertical" : true
        }
      }
    }
  ]
}