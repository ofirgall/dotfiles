#!/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

NUM_MONITORS=$(sketchybar --query displays | grep -c "arrangement-id")
if [ "$NUM_MONITORS" -eq 3 ]; then
    BUILTIN_DISPLAY=3
    EXTERNAL_DISPLAYS=1,2
else
    BUILTIN_DISPLAY=1
    EXTERNAL_DISPLAYS=
fi

sketchybar --bar \
    height=33 \
    blur_radius=30 \
    position=top \
    sticky=on \
    padding_left=10 \
    padding_right=10 \
    color=0xff151520 \
    notch_width=200

sketchybar --default \
    icon.font="CaskaydiaCove NFM:Bold:14.0" \
    label.font="CaskaydiaCove NFM:Regular:12.0" \
    icon.color=0xffcad3f5 \
    label.color=0xffcad3f5 \
    padding_left=5 \
    padding_right=5

# Aerospace workspaces
for sid in 1 2 3 4 5 6 7 8 9; do
    sketchybar --add event aerospace_workspace_change_"$sid" \
               --add item space."$sid" left \
               --subscribe space."$sid" aerospace_workspace_change_"$sid" forced \
               --set space."$sid" \
                    icon="$sid" \
                    icon.padding_left=8 \
                    icon.padding_right=4 \
                    label.font="CaskaydiaCove NFM:Regular:13.0" \
                    label.color=0xffcad3f5 \
                    label.drawing=off \
                    label.padding_right=6 \
                    background.color=0xffcba6f7 \
                    background.corner_radius=5 \
                    background.height=22 \
                    background.drawing=off \
                    click_script="~/dotfiles/dotfiles/mac/aerospace/switch-group.sh $sid" \
                    script="$PLUGIN_DIR/aerospace.sh $sid"
done

# Window count for focused workspace
sketchybar --add event window_count_change
WINDOW_COUNT_EVENTS="forced window_count_change"
for sid in 1 2 3 4 5 6 7 8 9; do
    WINDOW_COUNT_EVENTS="$WINDOW_COUNT_EVENTS aerospace_workspace_change_$sid"
done
# Laptop (notch display) — position 'e' shifts right of notch
sketchybar --add item window_count e \
           --subscribe window_count $WINDOW_COUNT_EVENTS \
           --set window_count \
                display=$BUILTIN_DISPLAY \
                icon="󰖯" \
                icon.padding_left=4 \
                label.padding_right=4 \
                script="$PLUGIN_DIR/window_count.sh" \
           --add item window_name e \
           --subscribe window_name $WINDOW_COUNT_EVENTS front_app_switched \
           --set window_name \
                display=$BUILTIN_DISPLAY \
                icon.drawing=off \
                label.max_chars=50 \
                script="$PLUGIN_DIR/window_count.sh"

# External monitors — true center
sketchybar --add item window_count_ext center \
           --subscribe window_count_ext $WINDOW_COUNT_EVENTS \
           --set window_count_ext \
                display=$EXTERNAL_DISPLAYS \
                icon="󰖯" \
                icon.padding_left=4 \
                label.padding_right=4 \
                script="$PLUGIN_DIR/window_count.sh" \
           --add item window_name_ext center \
           --subscribe window_name_ext $WINDOW_COUNT_EVENTS front_app_switched \
           --set window_name_ext \
                display=$EXTERNAL_DISPLAYS \
                icon.drawing=off \
                label.max_chars=50 \
                script="$PLUGIN_DIR/window_count.sh"

# Clock — yellow
sketchybar --add item clock right \
           --set clock update_freq=10 \
                 icon.color=0xfff9e2af \
                 label.color=0xfff9e2af \
                 script="$PLUGIN_DIR/clock.sh"

# Battery — green
sketchybar --add item battery right \
           --set battery update_freq=120 \
                 icon.color=0xffa6e3a1 \
                 label.color=0xffa6e3a1 \
                 script="$PLUGIN_DIR/battery.sh"

# Keyboard language — purple
sketchybar --add item keyboard right \
           --set keyboard update_freq=5 \
                 icon="󰌌" \
                 icon.color=0xffb459ff \
                 label.color=0xffb459ff \
                 script="$PLUGIN_DIR/keyboard.sh" \
           --subscribe keyboard front_app_switched

# Volume — sapphire (dynamic color in script for muted)
sketchybar --add item volume right \
           --set volume \
                 script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change

# Bluetooth — blue
sketchybar --add item bluetooth right \
           --set bluetooth update_freq=30 \
                 icon.color=0xff89b4fa \
                 label.color=0xff89b4fa \
                 script="$PLUGIN_DIR/bluetooth.sh"

# WiFi — teal (dynamic color in script for disconnected)
sketchybar --add item wifi right \
           --set wifi update_freq=30 \
                 script="$PLUGIN_DIR/wifi.sh" \
           --subscribe wifi wifi_change

# CPU — green
sketchybar --add item cpu right \
           --set cpu update_freq=10 \
                 icon="󰻠" \
                 icon.color=0xffa6e3a1 \
                 label.color=0xffa6e3a1 \
                 script="$PLUGIN_DIR/cpu.sh"

# RAM — sky
sketchybar --add item ram right \
           --set ram update_freq=10 \
                 icon="󰍛" \
                 icon.color=0xff89dceb \
                 label.color=0xff89dceb \
                 script="$PLUGIN_DIR/ram.sh"

# Media — lavender
sketchybar --add item media right \
           --set media update_freq=5 \
                 icon.color=0xffb4befe \
                 label.color=0xffb4befe \
                 label.max_chars=40 \
                 script="$PLUGIN_DIR/media.sh"

sketchybar --update

# Load agents-status workspace names after sketchybar init
(/opt/homebrew/bin/python3.14 /Users/ofirgal/agents-status/statusbar/run.py &)
