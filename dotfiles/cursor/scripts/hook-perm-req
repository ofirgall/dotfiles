#!/usr/bin/env sh

# Cursor has no way to tell hooks whether auto-run is active, so the same
# beforeShellExecution event fires for both real permission prompts and
# auto-approved commands. Mark the event deferred: the agents-status server
# holds it for ~1.5s and drops it if afterShellExecution arrives in the
# window (the auto-run case for short commands).
(
    . "$HOME/dotfiles_scripts/agents-status/helpers.sh"
    AGENTS_STATUS_DEFER=1 send_event cursor WAITING "Requires Permission"
) </dev/null >/dev/null 2>&1 &

printf '{"permission":"ask"}\n'
