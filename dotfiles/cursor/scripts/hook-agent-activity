#!/usr/bin/env sh
# Workaround: Cursor has no "plan approved" / "agent started executing" hook
# (see https://cursor.com/docs/hooks#hook-types — only sessionStart/End, stop,
# beforeSubmitPrompt, before/afterShellExecution, beforeReadFile, afterFileEdit
# are exposed). When the agent approves a plan and its first action is a file
# read or edit (not a shell command), nothing else would flip the status from
# WAITING/IDLE to INPROGRESS. So we treat any file-read or file-edit as
# evidence the agent is working and emit INPROGRESS here too.

(
    . "$HOME/dotfiles_scripts/agents-status/helpers.sh"
    send_event cursor INPROGRESS
) </dev/null >/dev/null 2>&1 &
