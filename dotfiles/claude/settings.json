{
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '~/.claude_scripts/hook-finish >/dev/null 2>&1 &'"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '~/.claude_scripts/hook-perm-req >/dev/null 2>&1 &'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '~/.claude_scripts/hook-session-start >/dev/null 2>&1 &'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '~/.claude_scripts/hook-session-stop >/dev/null 2>&1 &'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '~/.claude_scripts/hook-prompt-start >/dev/null 2>&1 &'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "medium",
  "skipAutoPermissionPrompt": true
}
