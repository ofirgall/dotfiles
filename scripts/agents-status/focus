#!/usr/bin/env sh
# focus SESSION WINDOW
# Switch tmux to SESSION:WINDOW and focus the terminal hosting that session
# in Hyprland.

session="$1"
window="$2"

[ -n "$session" ] || exit 0

if [ -n "$window" ]; then
    tmux select-window -t "$session:$window" 2>/dev/null
fi

command -v hyprctl >/dev/null 2>&1 || exit 0
command -v jq >/dev/null 2>&1 || exit 0

clients_json="$(hyprctl clients -j 2>/dev/null)"
[ -n "$clients_json" ] || exit 0

# Match by title (tmux sets the terminal title to '<session> - TMUX' via
# set-titles-string). Pid matching doesn't work for single-process terminals
# like ghostty/gnome-terminal where many windows share one pid.
match="$(printf '%s' "$clients_json" | jq -r --arg s "$session" \
    '.[] | select(.title == ($s + " - TMUX")) | "\(.address) \(.workspace.id)"' | head -1)"

if [ -z "$match" ]; then
    match="$(printf '%s' "$clients_json" | jq -r --arg s "$session" \
        '.[] | select(.title | startswith($s + " ") or . == $s) | "\(.address) \(.workspace.id)"' | head -1)"
fi

[ -n "$match" ] || exit 0
addr="${match%% *}"
ws="${match##* }"

# Switch vdesk first (virtual-desktops plugin) so focuswindow lands on the
# correct desktop on multi-monitor setups.
[ -n "$ws" ] && hyprctl dispatch vdesk "$ws" >/dev/null 2>&1
hyprctl dispatch focuswindow "address:$addr" >/dev/null 2>&1
