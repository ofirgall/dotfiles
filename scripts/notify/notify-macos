#!/usr/bin/env sh
# notify-send compatible wrapper for macOS using alerter.
# Usage: notify-macos [OPTIONS...] TITLE BODY
# Supports -u (urgency: critical disables timeout) and -A (actions, ignored).
#
# Global defaults — edit these to configure all notifications in one place.
# ALERTER_SOUND="Blow"
# ALERTER_SOUND="Funk"
ALERTER_SOUND="Tink"
# ALERTER_SOUND="Hero"
ALERTER_TIMEOUT=5
ALERTER_IGNORE_DND=1

while [ $# -gt 0 ]; do
    case "$1" in
        -u) urgency="$2"; shift 2 ;;
        -A) shift 2 ;;
        *)  break ;;
    esac
done

[ "$urgency" = "critical" ] && ALERTER_TIMEOUT=0

title="${1:-Notification}"
body="${2:-}"

args="--title '$title' --message '$body'"
[ -n "$ALERTER_SOUND" ] && args="$args --sound $ALERTER_SOUND"
[ -n "$ALERTER_TIMEOUT" ] && args="$args --timeout $ALERTER_TIMEOUT"
[ "$ALERTER_IGNORE_DND" = "1" ] && args="$args --ignore-dnd"

eval alerter $args >/dev/null 2>&1 &
