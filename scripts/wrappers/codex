#!/usr/bin/env sh
# Wrapper around codex that clears its agents-status entry on exit.
#
# Codex has no SessionEnd hook (only SessionStart/Stop/etc — see
# dotfiles/codex/hooks.json), so without this the pane's status would stick at
# DONE after the session ends. This mirrors the SessionEnd hook that claude and
# cursor get. Runs in the same pane/tty as the session, so the clear targets the
# same instance_id the hooks set.
#
# This dir is on PATH ahead of ~/.local/bin, so it shadows the real `codex`.
# Resolve the next `codex` on PATH (skipping this wrapper) to avoid recursion.

self_dir=$(CDPATH= cd -- "$(dirname -- "$0")" 2>/dev/null && pwd)
real=""
IFS=:
for d in $PATH; do
    [ "$d" = "$self_dir" ] && continue
    if [ -x "$d/codex" ]; then
        real="$d/codex"
        break
    fi
done
unset IFS
[ -n "$real" ] || real="$HOME/.local/bin/codex"

cleanup_done=0
cleanup_status() {
    [ "$cleanup_done" -eq 0 ] || return
    cleanup_done=1

    ( . "$HOME/dotfiles_scripts/agents-status/helpers.sh"
      send_event codex "" "" clear ) >/dev/null 2>&1
}

signal_exit() {
    status="$1"
    trap - EXIT HUP TERM
    cleanup_status
    exit "$status"
}

trap cleanup_status EXIT
trap 'signal_exit 129' HUP
trap 'signal_exit 143' TERM

# Session start: ensure the agents-status server is up and mark idle. Done here
# rather than via a SessionStart hook so it runs once per real launch (the hook
# also fires on resume/compact) and so the server is guaranteed running before
# Codex's first hook fires. Synchronous on purpose - the hooks no longer call
# ensure_server, so this must finish before the TUI starts.
( . "$HOME/dotfiles_scripts/agents-status/helpers.sh"
  ensure_server
  send_event codex IDLE ) >/dev/null 2>&1

"$real" "$@"
ret=$?

exit "$ret"
